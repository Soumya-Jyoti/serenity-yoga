{
  "name": "serenity-yoga-studio",
  "version": "1.0.0",
  "description": "Premium Yoga Studio Platform",
  "private": true,
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" -n \"backend,frontend\" -c \"blue,green\"",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "start": "npm run start --prefix backend"
  },
  "dependencies": {
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
